DATABASE_URL="postgresql://postgres:password@localhost:5432/indoor_positioning?schema=public"
PORT=3000

# Fingerprint scan window validation bounds (ms)
FINGERPRINT_SCAN_MS_DEFAULT=5000
FINGERPRINT_SCAN_MS_MIN=1000
FINGERPRINT_SCAN_MS_MAX=30000

# Navimind Chatbot Service (Qwen2.5-3B + RAG brain — see /chatbot-service).
# The backend proxies each chat turn here; if unreachable it falls back to the
# local rule-based pipeline. Qwen on CPU can take a few seconds, so the timeout
# is generous.
CHATBOT_SERVICE_URL="http://127.0.0.1:8000"
CHATBOT_SERVICE_TIMEOUT_MS=60000
CHATBOT_SERVICE_TOKEN=""

