DATABASE_URL="postgresql://postgres:password@localhost:5432/indoor_positioning?schema=public"
PORT=3000
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"


# Public base URL used in live-location share / friend-invite links
# (must be reachable from phones, e.g. your LAN IP or a tunnel).
PUBLIC_URL="http://192.168.1.10:3000"

# Fingerprint scan window validation bounds (ms)
FINGERPRINT_SCAN_MS_DEFAULT=5000
FINGERPRINT_SCAN_MS_MIN=1000
FINGERPRINT_SCAN_MS_MAX=30000

# Navimind Chatbot Service (Qwen2.5-3B + RAG brain — see /chatbot-service).
# The backend proxies each chat turn here; if unreachable it falls back to the
# local rule-based pipeline. Qwen on CPU can take a few seconds, so the timeout
# is generous.
CHATBOT_SERVICE_URL="http://127.0.0.1:8000"
CHATBOT_SERVICE_TIMEOUT_MS=60000
CHATBOT_SERVICE_TOKEN=""

# Internal staff access (dashboard admin) — there's no separate staff login;
# a User becomes staff when internalRoleId is set (see schema.prisma). This
# bootstraps the first SUPER_ADMIN, via `npx ts-node prisma/seed-internal-rbac.ts`
# (only if no User has internalRoleId set yet — safe to leave set after first run).
SEED_INTERNAL_ADMIN_EMAIL="admin@navimind.local"
SEED_INTERNAL_ADMIN_PASSWORD="change-me"

