generator client {
  provider        = "prisma-client"
  previewFeatures = ["fullTextSearchPostgres"]
  output          = "../src/generated/prisma"
}

generator dbml {
  provider   = "prisma-dbml-generator"
  output     = "../../GraduationProject/docs/diagrams"
  outputName = "database-schema.dbml"
}

datasource db {
  provider = "postgresql"
}

// -------------------- Core structure --------------------

model Building {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  // Geofence — set/maintained via raw SQL (PostGIS). `zone` is the polygon a
  // user must enter to be considered "at" the building; `centroid` is used
  // for distance ordering when they're nearby but not yet inside.
  zone     Unsupported("geometry(Polygon, 4326)")?
  centroid Unsupported("geometry(Point, 4326)")?

  floors                 Floor[]
  beacons                BleBeacon[]
  envModels              BleEnvModel[]
  fingerprints           BleFingerprint[]
  fingerprintSessions    FingerprintSession[]
  aggregatedFingerprints AggregatedFingerprint[]
  mapNodes               MapNode[]
  pois                   Poi[]
  wifiAccessPoints       WifiAccessPoint[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  measurements Measurement[]
}

model Floor {
  id         String   @id @default(cuid())
  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  level  Int // e.g. 0 = ground, 1 = first, etc.
  name   String
  mapUrl String? // URL to the floor plan image

  // Reverse relations
  // Note: Some relations are defined on the other side, but we can add them here for convenience if needed.
  // For now, we rely on the building-level relations + floorLevel filtering, 
  // or we can add specific relations if Prisma requires them for strict integrity.
  // The user's schema didn't explicitly link Beacons to Floor *model*, just via integer level.
  // We will keep it flexible as per suggestion.

  @@unique([buildingId, level])
}

// -------------------- BLE beacons & models --------------------

model BleBeacon {
  id        String @id @default(cuid())
  beaconUid String @unique // iBeacon UUID+major+minor or custom ID (the ML model identity)

  // 0xFFF0 service-data hex (lowercased). Both Android & iOS read this from the
  // advertisement (iOS hides the iBeacon manufacturer data but NOT service data),
  // so it is the cross-platform key: iOS scans 0xFFF0 -> looks up beaconUid.
  serviceData String?

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int // reference to Floor.level
  x          Float // local coords in meters
  y          Float

  txPowerDbm   Float? // nominal Tx power
  refRssi1mDbm Float? // measured RSSI at 1 m after calibration

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId, floorLevel])
}

model BleEnvModel {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int? // null = building default, or per floor

  nExponent   Float // path-loss exponent
  shadowSigma Float? // std dev of shadowing noise (optional)

  lastCalibratedAt DateTime?

  @@unique([buildingId, floorLevel])
}

// -------------------- Fingerprints --------------------

/// One collection run for a building/floor. Groups every BleFingerprint
/// and (transitively) every RawRssiReading captured during that run.
model FingerprintSession {
  id              String           @id @default(cuid())
  building        Building         @relation(fields: [buildingId], references: [id])
  buildingId      String
  floorLevel      Int
  name            String? // e.g. "Initial Survey", "Recalibration March 2025"
  deviceModel     String? // Collection device info
  collectorId     String? // Admin user ID
  gridSpacing     Float            @default(1.0) // meters between collection points
  pointDurationMs Int? // ms to scan at each collection point; null = app default
  status          SessionStatus    @default(IN_PROGRESS)
  startedAt       DateTime         @default(now())
  completedAt     DateTime?
  fingerprints    BleFingerprint[]

  @@index([buildingId, floorLevel])
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

/// One scan window at one (x, y): the cleaned, IQR-median RSSI per beacon.
/// This is what positioning (k-NN / fingerprint matching) consumes.
model BleFingerprint {
  id String @id @default(cuid())

  building   Building            @relation(fields: [buildingId], references: [id])
  buildingId String
  session    FingerprintSession? @relation(fields: [sessionId], references: [id])
  sessionId  String?

  floorLevel Int
  x          Float
  y          Float

  beaconUids String[] // ordered list of beacon IDs
  rssis      Int[] // same length as beaconUids, IQR-filtered median RSSI in dBm

  durationMs Int? // scan window length used to collect this sample

  deviceModel String?
  layoutTag   String? // e.g. "layout1", "layout2"
  sampleIndex Int? // Which sample in group (e.g., 1-30 at same point)

  rawReadings  RawRssiReading[]
  wifiReadings WifiReading[]

  createdAt DateTime @default(now())

  @@index([buildingId, floorLevel])
  @@index([sessionId])
}

/// One BLE advertisement: a per-packet RSSI sample with timestamp and
/// optional gyroscope. Kept for ML training (GP/GMM). Positioning code
/// must not read this — use BleFingerprint.rssis (the IQR-median).
///
/// Window grouping: the mobile client collects one point as N sequential
/// windows. Each window becomes one parent BleFingerprint (its `sampleIndex`
/// is the 0-based window index within the point). `windowIndex` here is the
/// same value, denormalized so ML exports can group/filter on it without
/// joining BleFingerprint.
model RawRssiReading {
  id            String         @id @default(cuid())
  fingerprint   BleFingerprint @relation(fields: [fingerprintId], references: [id], onDelete: Cascade)
  fingerprintId String

  // Denormalized from parent BleFingerprint for easy ML export (no join needed)
  x           Float
  y           Float
  windowIndex Int   @default(0) // 0-based window index within the point

  beaconUid  String
  rssi       Int
  capturedAt DateTime // absolute wall-clock timestamp of this advertisement

  // Gyroscope — rotation rate (rad/s)
  gyroX Float?
  gyroY Float?
  gyroZ Float?

  // Raw accelerometer including gravity (g)
  accelX Float?
  accelY Float?
  accelZ Float?

  // Gravity-removed acceleration from DeviceMotion (m/s²)
  userAccelX Float?
  userAccelY Float?
  userAccelZ Float?

  // Magnetometer — raw geomagnetic field (µT)
  magX Float?
  magY Float?
  magZ Float?

  // Attitude from OS-fused DeviceMotion (rad)
  pitch Float?
  roll  Float?
  yaw   Float?

  // Environmental
  pressure         Float? // barometer (hPa)
  relativeAltitude Float? // iOS only (m)

  @@index([fingerprintId])
  @@index([beaconUid])
  @@index([capturedAt])
  @@index([x, y])
  @@index([fingerprintId, windowIndex])
}

/// Registered WiFi access points for a building. Admin-managed — mirrors BleBeacon.
/// Only APs in this table will have their RSSI recorded during fingerprinting.
model WifiAccessPoint {
  id          String   @id @default(cuid())
  building    Building @relation(fields: [buildingId], references: [id])
  buildingId  String

  bssid       String  // MAC address — unique per building
  ssid        String? // display name (not unique — informational only)
  description String?
  floorLevel  Int?    // null = visible on all floors
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buildingId, bssid])
  @@index([buildingId])
}

/// Per-fingerprint-window WiFi scan results (only registered APs).
/// One-shot scan per collection window; cascade-deletes with its parent BleFingerprint.
model WifiReading {
  id            String         @id @default(cuid())
  fingerprint   BleFingerprint @relation(fields: [fingerprintId], references: [id], onDelete: Cascade)
  fingerprintId String

  bssid        String
  ssid         String?
  rssi         Int
  frequencyMhz Int?
  capturedAt   DateTime

  @@index([fingerprintId])
  @@index([bssid])
}

/// The radio map: one row per (building, floor, gridX, gridY) with
/// mean + stddev per beacon across every sample at that point. This is
/// what live positioning matches against.
model AggregatedFingerprint {
  id         String   @id @default(cuid())
  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String
  floorLevel Int
  gridX      Float // Grid point X coordinate
  gridY      Float // Grid point Y coordinate

  beaconUids  String[] // Ordered beacon UIDs
  rssiMeans   Float[] // Mean RSSI per beacon
  rssiStdDevs Float[] // Std deviation per beacon (for filtering outliers)
  sampleCount Int // Number of samples aggregated

  sessionId String? // Which session produced this
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buildingId, floorLevel, gridX, gridY])
  @@index([buildingId, floorLevel])
}

model Measurement {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorHint Int?
  deviceId  String?
  method    String? // "trilateration" | "fingerprint" | "hybrid"

  beaconUids String[]
  rssis      Int[]

  estX      Float?
  estY      Float?
  estFloor  Int?
  accuracyM Float?

  createdAt DateTime @default(now())

  @@index([buildingId, createdAt])
}

// -------------------- Indoor map & routing --------------------

model MapNode {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int
  x          Float
  y          Float

  type MapNodeType

  poi   Poi?    @relation(fields: [poiId], references: [id])
  poiId String?

  edgesFrom MapEdge[] @relation("EdgesFrom")
  edgesTo   MapEdge[] @relation("EdgesTo")

  @@index([buildingId, floorLevel])
}

model MapEdge {
  id String @id @default(cuid())

  fromNode   MapNode @relation("EdgesFrom", fields: [fromNodeId], references: [id])
  fromNodeId String

  toNode   MapNode @relation("EdgesTo", fields: [toNodeId], references: [id])
  toNodeId String

  cost Float // distance, + floor-change penalty etc.

  bidirectional Boolean @default(true)
}

enum MapNodeType {
  CORRIDOR
  ROOM_ENTRANCE
  STAIRS
  ELEVATOR
}

// -------------------- POIs (rooms, etc.) --------------------

model Poi {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int

  name String
  code String? // room number (e.g. "C3-305")
  type PoiType

  x Float
  y Float

  node MapNode[]

  @@index([buildingId, floorLevel])
}

enum PoiType {
  ROOM
  LAB
  TOILET
  STAIRS
  ELEVATOR
  OTHER
}

// -------------------- Auth --------------------

/// A registered Navimind user. May be linked to multiple Identity rows
/// (one per OAuth provider). Email is optional because Apple may relay a
/// hidden "private relay" address that the user can revoke later.
model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identities Identity[]
}

enum AuthProvider {
  GOOGLE
  APPLE
}

/// One row per (provider, user-on-that-provider) link. The (provider,
/// providerUserId) pair is the unique sign-in key — `providerUserId` is
/// the `sub` claim from Google/Apple ID tokens.
model Identity {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  provider       AuthProvider
  providerUserId String
  createdAt      DateTime     @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

// -------------------- Trajectory-based fingerprinting (collection only) --------------------
//
// Parallel pipeline to the point-based BleFingerprint flow above. We persist
// raw walks (continuous IMU + BLE + WiFi streams plus on-device step events)
// so a downstream ML team can train sequence models without us locking them
// into a particular segmentation or labelling strategy.
//
// Isolated from the existing fingerprint tables: `buildingId` is stored as a
// plain string with the FK enforced only in raw SQL (see migration), so this
// section adds no fields/relations to Building, Floor, or any existing model.

model TrajectorySession {
  id           String                @id @default(cuid())
  buildingId   String
  floorLevel   Int
  name         String?
  deviceModel  String?
  collectorId  String?
  notes        String?
  status       SessionStatus         @default(IN_PROGRESS)
  startedAt    DateTime              @default(now())
  completedAt  DateTime?

  // Environment versioning + capture conditions (B4). All nullable so the AI
  // team can stratify the dataset by map/layout revision and by ambient state
  // (a fingerprint collected in a crowded hall at rush hour decays differently
  // from an empty one). Versions are free-running ints the collector bumps when
  // the floor plan or beacon layout changes.
  buildingVersion     Int?
  beaconLayoutVersion Int?
  timeOfDay           String?   // MORNING | MIDDAY | EVENING | NIGHT (free text)
  crowdLevel          String?   // EMPTY | LIGHT | MODERATE | CROWDED (free text)

  // Carry mode + device pose (B5) — body shadowing & stride dynamics depend on
  // how the phone is held. Session-level defaults; recorder may also stamp the
  // walk. phoneAttitude is a coarse descriptor (PORTRAIT/FLAT/...).
  carryMode     String?   // HAND | SWING | POCKET | BACKPACK
  phoneAttitude String?

  walks        TrajectoryWalk[]

  @@index([buildingId, floorLevel])
}

/// One continuous walk from a start waypoint (startX, startY) to an end
/// waypoint (endX, endY). `totalSteps` is the on-device step count between
/// the two taps; the server uses it to linearly interpolate a per-step (x, y)
/// label on the line segment.
model TrajectoryWalk {
  id          String              @id @default(cuid())
  session     TrajectorySession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String
  buildingId  String
  floorLevel  Int
  startX      Float
  startY      Float
  endX        Float
  endY        Float
  startedAt   DateTime
  endedAt     DateTime
  totalSteps  Int
  deviceModel String?
  createdAt   DateTime            @default(now())

  // Idempotency (B6): device-generated UUID per walk. uploadWalks() skips a
  // walk whose (sessionId, clientId) already exists so retries after a flaky
  // upload don't duplicate. Nullable for legacy rows.
  clientId    String?

  // Replay clock anchor (B1): wall-clock ms (Date.now()) captured at walk
  // start. Per-sample absolute time = clockEpochMs + tMs. The relative tMs on
  // each child row comes from a monotonic clock so it is immune to wall-clock
  // jumps mid-walk; clockEpochMs only maps the walk onto the calendar.
  clockEpochMs Float?

  // Sensor metadata (B5): the IMU sampling rate actually used and whether the
  // magnetometer was calibrated (Expo's magnetometer is uncalibrated → usually
  // null/false). Walk-level so mixed-device sessions stay analyzable.
  imuRateHz     Int?
  magCalibrated Boolean?

  steps       TrajectoryStepEvent[]
  imuSamples  TrajectoryImuSample[]
  bleReadings TrajectoryBleReading[]
  wifiReadings TrajectoryWifiReading[]
  checkpoints TrajectoryCheckpoint[]

  @@unique([sessionId, clientId])
  @@index([sessionId])
  @@index([buildingId, floorLevel])
}

/// Intermediate ground-truth waypoint marked mid-walk (B2). The collector taps
/// "Mark checkpoint" when physically at a known (x, y); the server uses these
/// plus the start/end anchors to build a piecewise-linear time→position label,
/// so curved/non-uniform walks are labelled correctly (vs. the old straight-line
/// stepIndex/totalSteps assumption). `seq` orders them within the walk; `tMs` is
/// the same monotonic-relative clock as the IMU/BLE rows.
model TrajectoryCheckpoint {
  id         String         @id @default(cuid())
  walk       TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId     String

  seq        Int
  x          Float
  y          Float
  tMs        Float
  capturedAt DateTime

  @@index([walkId, seq])
}

/// One footstep detected on-device (peak-valley detector). `interpolatedX/Y`
/// is the server-computed label = start + (stepIndex / totalSteps) * (end - start).
model TrajectoryStepEvent {
  id             String          @id @default(cuid())
  walk           TrajectoryWalk  @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId         String

  stepIndex      Int             // 0-based within walk
  capturedAt     DateTime
  tMs            Float?          // monotonic ms since walk start (B1) — replay clock
  headingRad     Float           // device heading at the moment the step fired
  interpolatedX  Float           // server-computed waypoint-anchored label
  interpolatedY  Float

  @@index([walkId, stepIndex])
}

/// Raw IMU stream at ~20 Hz. Column shape mirrors RawRssiReading's IMU columns
/// for AI-team familiarity. All sensor fields nullable — not every device emits
/// every channel.
model TrajectoryImuSample {
  id         String         @id @default(cuid())
  walk       TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId     String

  capturedAt DateTime
  tMs        Float?  // monotonic ms since walk start (B1) — replay clock

  // Gyroscope (rad/s)
  gyroX Float?
  gyroY Float?
  gyroZ Float?

  // Raw accelerometer including gravity (g)
  accelX Float?
  accelY Float?
  accelZ Float?

  // Gravity-removed acceleration (m/s²)
  userAccelX Float?
  userAccelY Float?
  userAccelZ Float?

  // Magnetometer (µT)
  magX Float?
  magY Float?
  magZ Float?

  // Attitude from OS-fused DeviceMotion (rad)
  pitch Float?
  roll  Float?
  yaw   Float?

  // Environmental
  pressure         Float?
  relativeAltitude Float?

  @@index([walkId, capturedAt])
}

/// One BLE advertisement captured during the walk.
model TrajectoryBleReading {
  id         String         @id @default(cuid())
  walk       TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId     String

  capturedAt DateTime
  tMs        Float?  // monotonic ms since walk start (B1) — replay clock
  beaconUid  String
  rssi       Int

  @@index([walkId, capturedAt])
  @@index([walkId, beaconUid])
}

/// One WiFi scan entry captured during the walk.
model TrajectoryWifiReading {
  id           String         @id @default(cuid())
  walk         TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId       String

  capturedAt   DateTime
  tMs          Float?  // monotonic ms since walk start (B1) — replay clock
  bssid        String
  ssid         String?
  rssi         Int
  frequencyMhz Int?

  @@index([walkId, capturedAt])
  @@index([walkId, bssid])
}
