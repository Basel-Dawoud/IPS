generator client {
  provider        = "prisma-client"
  previewFeatures = ["fullTextSearchPostgres"]
  output          = "../src/generated/prisma"
}

generator dbml {
  provider   = "prisma-dbml-generator"
  output     = "../../docs/diagrams"
  outputName = "database-schema.dbml"
}

datasource db {
  provider = "postgresql"
}


model Building {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  imageUrl    String? 

  zone     Unsupported("geometry(Polygon, 4326)")?
  centroid Unsupported("geometry(Point, 4326)")?

  pinLat Float?
  pinLng Float?

  // Compass bearing (deg, 0-360) that the floor map's "up" (-y) direction
  // points toward in the real world. Calibrated on-site; drives the user
  // direction cone on the app's Navigate map.
  northOffsetDeg Float?

  floors                 Floor[]
  beacons                BleBeacon[]
  envModels              BleEnvModel[]
  fingerprints           BleFingerprint[]
  fingerprintSessions    FingerprintSession[]
  aggregatedFingerprints AggregatedFingerprint[]
  mapNodes               MapNode[]
  pois                   Poi[]
  wifiAccessPoints       WifiAccessPoint[]
  chatSessions           ChatSession[]
  buildingVisits         BuildingVisit[]

  products               Product[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  poiUpdatedAt DateTime      @default(now())
  // Version stamp for the product catalog, mirroring poiUpdatedAt. The chatbot
  // service caches products per building keyed by this timestamp.
  productUpdatedAt DateTime  @default(now())
  measurements Measurement[]
  emergencyAlert EmergencyAlert?
}

model Floor {
  id         String   @id @default(cuid())
  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  level  Int // e.g. 0 = ground, 1 = first, etc.
  name   String
  mapUrl String? // URL to the floor plan image

  // Real-world extent of the floor plan, used by the dashboard POI picker to
  // map a click on the plan image to (x, y) meters. Derived from the calibration
  // below (imageWidthPx * metersPerPixel, imageHeightPx * metersPerPixel); kept
  // denormalized for the picker. Null until the floor is calibrated.
  widthMeters  Float?
  heightMeters Float?

  // Pixel↔meter calibration for the plan image (moved out of the app's
  // hardcoded constants). `imageWidthPx`/`imageHeightPx` are the natural
  // (as-uploaded) pixel dimensions; `metersPerPixel` is the uniform scale;
  // `rotationDeg` (0/90/180/270) is how the image is rotated relative to the
  // model coordinate frame; `originXm`/`originYm` offset the image's top-left
  // from the world origin in meters.
  imageWidthPx   Int?
  imageHeightPx  Int?
  metersPerPixel Float?
  rotationDeg    Int   @default(0)
  originXm       Float @default(0)
  originYm       Float @default(0)

  // Vector floor map derived from an uploaded `.npy` grid: merged wall/corridor
  // rectangles + per-room polygons in METER coords, rendered as crisp SVG by the
  // app. Null for floors uploaded as raster images (those use mapUrl instead).
  vectorMap Json?



  @@unique([buildingId, level])
}


model BleBeacon {
  id        String @id @default(cuid())
  beaconUid String @unique // iBeacon UUID+major+minor or custom ID (the ML model identity)

  // 0xFFF0 service-data hex (lowercased). Both Android & iOS read this from the
  // advertisement (iOS hides the iBeacon manufacturer data but NOT service data),
  // so it is the cross-platform key: iOS scans 0xFFF0 -> looks up beaconUid.
  serviceData String?

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int // reference to Floor.level
  x          Float // local coords in meters
  y          Float

  txPowerDbm   Float? // nominal Tx power
  refRssi1mDbm Float? // measured RSSI at 1 m after calibration

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId, floorLevel])
}

model BleEnvModel {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int? // null = building default, or per floor

  nExponent   Float // path-loss exponent
  shadowSigma Float? // std dev of shadowing noise (optional)

  lastCalibratedAt DateTime?

  @@unique([buildingId, floorLevel])
}

//FINGERPRINTS

model FingerprintSession {
  id              String           @id @default(cuid())
  building        Building         @relation(fields: [buildingId], references: [id])
  buildingId      String
  floorLevel      Int
  name            String? // e.g. "Initial Survey", "Recalibration March 2025"
  deviceModel     String? // Collection device info
  collectorId     String? // Admin user ID
  gridSpacing     Float            @default(1.0) // meters between collection points
  pointDurationMs Int? // ms to scan at each collection point; null = app default
  status          SessionStatus    @default(IN_PROGRESS)
  startedAt       DateTime         @default(now())
  completedAt     DateTime?
  fingerprints    BleFingerprint[]

  @@index([buildingId, floorLevel])
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

/// One scan window at one (x, y): the cleaned, IQR-median RSSI per beacon.
/// This is what positioning (k-NN / fingerprint matching) consumes.
model BleFingerprint {
  id String @id @default(cuid())

  building   Building            @relation(fields: [buildingId], references: [id])
  buildingId String
  session    FingerprintSession? @relation(fields: [sessionId], references: [id])
  sessionId  String?

  floorLevel Int
  x          Float
  y          Float

  beaconUids String[]
  rssis      Int[] 

  durationMs Int? 

  deviceModel String?
  layoutTag   String? // e.g. "layout1", "layout2"
  sampleIndex Int? // Which sample in group (e.g., 1-30 at same point)

  rawReadings  RawRssiReading[]
  wifiReadings WifiReading[]

  createdAt DateTime @default(now())

  @@index([buildingId, floorLevel])
  @@index([sessionId])
}

/// One BLE advertisement: a per-packet RSSI sample with timestamp and
/// optional gyroscope. Kept for ML training (GP/GMM). Positioning code
/// must not read this — use BleFingerprint.rssis (the IQR-median).
///
/// Window grouping: the mobile client collects one point as N sequential
/// windows. Each window becomes one parent BleFingerprint (its `sampleIndex`
/// is the 0-based window index within the point). `windowIndex` here is the
/// same value, denormalized so ML exports can group/filter on it without
/// joining BleFingerprint.
model RawRssiReading {
  id            String         @id @default(cuid())
  fingerprint   BleFingerprint @relation(fields: [fingerprintId], references: [id], onDelete: Cascade)
  fingerprintId String

  // Denormalized from parent BleFingerprint for easy ML export (no join needed)
  x           Float
  y           Float
  windowIndex Int   @default(0) // 0-based window index within the point

  beaconUid  String
  rssi       Int
  capturedAt DateTime // absolute wall-clock timestamp of this advertisement

  // Gyroscope — rotation rate (rad/s)
  gyroX Float?
  gyroY Float?
  gyroZ Float?

  // Raw accelerometer including gravity (g)
  accelX Float?
  accelY Float?
  accelZ Float?

  // Gravity-removed acceleration from DeviceMotion (m/s²)
  userAccelX Float?
  userAccelY Float?
  userAccelZ Float?

  // Magnetometer — raw geomagnetic field (µT)
  magX Float?
  magY Float?
  magZ Float?

  // Attitude from OS-fused DeviceMotion (rad)
  pitch Float?
  roll  Float?
  yaw   Float?

  // Environmental
  pressure         Float? // barometer (hPa)
  relativeAltitude Float? // iOS only (m)

  @@index([fingerprintId])
  @@index([beaconUid])
  @@index([capturedAt])
  @@index([x, y])
  @@index([fingerprintId, windowIndex])
}

/// Registered WiFi access points for a building. Admin-managed — mirrors BleBeacon.
/// Only APs in this table will have their RSSI recorded during fingerprinting.
model WifiAccessPoint {
  id          String   @id @default(cuid())
  building    Building @relation(fields: [buildingId], references: [id])
  buildingId  String

  bssid       String  // MAC address — unique per building
  ssid        String? // display name (not unique — informational only)
  description String?
  floorLevel  Int?    // null = visible on all floors
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buildingId, bssid])
  @@index([buildingId])
}

/// Per-fingerprint-window WiFi scan results (only registered APs).
/// One-shot scan per collection window; cascade-deletes with its parent BleFingerprint.
model WifiReading {
  id            String         @id @default(cuid())
  fingerprint   BleFingerprint @relation(fields: [fingerprintId], references: [id], onDelete: Cascade)
  fingerprintId String

  bssid        String
  ssid         String?
  rssi         Int
  frequencyMhz Int?
  capturedAt   DateTime

  @@index([fingerprintId])
  @@index([bssid])
}

model AggregatedFingerprint {
  id         String   @id @default(cuid())
  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String
  floorLevel Int
  gridX      Float // Grid point X coordinate
  gridY      Float // Grid point Y coordinate

  beaconUids  String[] // Ordered beacon UIDs
  rssiMeans   Float[] // Mean RSSI per beacon
  rssiStdDevs Float[] // Std deviation per beacon (for filtering outliers)
  sampleCount Int // Number of samples aggregated

  sessionId String? // Which session produced this
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buildingId, floorLevel, gridX, gridY])
  @@index([buildingId, floorLevel])
}

model Measurement {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorHint Int?
  deviceId  String?
  method    String? // "trilateration" | "fingerprint" | "hybrid"

  beaconUids String[]
  rssis      Int[]

  estX      Float?
  estY      Float?
  estFloor  Int?
  accuracyM Float?

  createdAt DateTime @default(now())

  @@index([buildingId, createdAt])
}


model MapNode {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int
  x          Float
  y          Float

  type MapNodeType

  poi   Poi?    @relation(fields: [poiId], references: [id])
  poiId String?

  edgesFrom MapEdge[] @relation("EdgesFrom")
  edgesTo   MapEdge[] @relation("EdgesTo")

  @@index([buildingId, floorLevel])
}

model MapEdge {
  id String @id @default(cuid())

  fromNode   MapNode @relation("EdgesFrom", fields: [fromNodeId], references: [id])
  fromNodeId String

  toNode   MapNode @relation("EdgesTo", fields: [toNodeId], references: [id])
  toNodeId String

  cost Float

  bidirectional Boolean @default(true)
}

enum MapNodeType {
  CORRIDOR
  ROOM_ENTRANCE
  STAIRS
  ELEVATOR
}


model Poi {
  id String @id @default(cuid())

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  floorLevel Int

  name String
  code String? 
  type PoiType

  iconUrl String?

  x Float
  y Float

 
  areaX Float?
  areaY Float?
  areaW Float?
  areaH Float?


  description     String? 
  category        PoiCategory? @relation(fields: [categoryId], references: [id])
  categoryId      String?
  aliases         String[] @default([]) 
  productKeywords String[] @default([]) 
  images          String[] @default([])

  avgRating   Float @default(0)
  reviewCount Int   @default(0)
  visitCount  Int   @default(0)

  active Boolean @default(true)

  node           MapNode[]
  visits         PoiVisit[]
  reviews        PoiReview[]
  deals          Deal[]
  buildingVisits BuildingVisit[]
  products       Product[]

  isEmergencyExit Boolean @default(false)
  isGatheringPoint Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId, floorLevel])
}

enum PoiType {
  ROOM
  LAB
  TOILET
  STAIRS
  ELEVATOR
  OTHER
  STORE
}


model PoiCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  pois        Poi[]
  users       User[]   @relation("UserInterests")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A purchasable product sold by a store (Poi). Seeded from the AI engineer's
// sort_data.json. The chatbot service fetches these per building (cached by
// Building.productUpdatedAt) to answer product-recommendation requests.
model Product {
  id String @id @default(cuid())

  name        String
  brand       String?
  // Price stored as an integer (currency-agnostic minor-unitless value); the
  // source strings like "₹7,989" are digit-stripped at seed time.
  price       Int     @default(0)
  rating      Float   @default(0)
  reviewCount Int     @default(0)

  // Taxonomy carried over from sort_data.json (e.g. category "Mobiles",
  // subCategory "Samsung mobiles"). Used to group/rank within a store.
  category    String?
  subCategory String?

  // The store that sells it. Nullable so a product whose category can't be
  // mapped to a Poi is still retained.
  poi   Poi?    @relation(fields: [poiId], references: [id], onDelete: SetNull)
  poiId String?

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([poiId])
}

model PoiVisit {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  poi        Poi      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId      String
  buildingId String
  confirmed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, poiId])
  @@index([userId, buildingId])
}

model PoiReview {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  poi       Poi      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId     String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, poiId])
  @@index([poiId])
}


model Deal {
  id          String    @id @default(cuid())
  poi         Poi       @relation(fields: [poiId], references: [id], onDelete: Cascade)
  poiId       String
  title       String               
  description String?              
  imageUrl    String?            
  discountPct Int?                  
  validFrom   DateTime  @default(now())
  validUntil  DateTime?           
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([poiId])
  @@index([active, validUntil])
}


model BuildingVisit {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  building   Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId String
  // The shop (POI) the user chose to navigate to on this visit, if any.
  poi        Poi?      @relation(fields: [poiId], references: [id], onDelete: SetNull)
  poiId      String?
  enteredAt  DateTime  @default(now())
  leftAt     DateTime?

  @@index([userId, enteredAt])
  @@index([buildingId])
}

model User {
  id                 String        @id @default(cuid())
  email              String?       @unique
  name               String?
  avatarUrl          String?
  passwordHash       String?
  interests          PoiCategory[] @relation("UserInterests")
  onboardingComplete Boolean       @default(false)
  age                Int?
  gender             String?       // "MALE" | "FEMALE" | "OTHER"
  needsStepFree      Boolean       @default(false) // prefers elevators over stairs (accessibility)
  shareWithFriends   Boolean       @default(true)  // friends can see my in-building presence
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  identities     Identity[]
  chatSessions   ChatSession[]
  poiVisits      PoiVisit[]
  poiReviews     PoiReview[]
  buildingVisits BuildingVisit[]
  locationShares LocationShare[]
  friendshipsInitiated Friendship[] @relation("FriendshipRequester")
  friendshipsReceived  Friendship[] @relation("FriendshipAddressee")
  presence       UserPresence?

  // Internal/staff access.
  internalRoleId String?
  internalRole   InternalRole? @relation(fields: [internalRoleId], references: [id])
}


model LocationShare {
  id             String    @id @default(cuid())
  token          String    @unique
  code           String?    @unique // 6-char A-Z2-9, for manual entry
  owner          User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId        String
  buildingId     String?
  expiresAt      DateTime? 
  endedAt        DateTime? 
  lastX          Float?
  lastY          Float?
  lastFloorLevel Int?
  lastUpdateAt   DateTime?
  createdAt      DateTime  @default(now())

  @@index([ownerId, endedAt])
}

/// One row per accepted pair (requester = who created the invite).
model Friendship {
  id          String   @id @default(cuid())
  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User     @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  createdAt   DateTime @default(now())

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

/// Invite for becoming friends, redeemable via link/QR (token) or typed code.
model FriendInvite {
  id        String   @id @default(cuid())
  token     String   @unique // nanoid, for link/QR
  code      String   @unique // 6-char A-Z0-9, for manual entry
  ownerId   String
  usedById  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([ownerId])
}

/// Latest known in-building position per user (upserted, throttled).
model UserPresence {
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @id
  buildingId String?
  x          Float?
  y          Float?
  floorLevel Int?
  updatedAt  DateTime @updatedAt
}

enum AuthProvider {
  GOOGLE
  APPLE
}


model Identity {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  provider       AuthProvider
  providerUserId String
  createdAt      DateTime     @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}


model InternalRole {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  permissions InternalRolePermission[]
}

model InternalPermission {
  id          String  @id @default(cuid())
  key         String  @unique 
  description String?

  roles InternalRolePermission[]
}

model InternalRolePermission {
  roleId       String
  role         InternalRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   InternalPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}


model TrajectorySession {
  id           String                @id @default(cuid())
  buildingId   String
  floorLevel   Int
  name         String?
  deviceModel  String?
  collectorId  String?
  notes        String?
  status       SessionStatus         @default(IN_PROGRESS)
  startedAt    DateTime              @default(now())
  completedAt  DateTime?

  buildingVersion     Int?
  beaconLayoutVersion Int?
  timeOfDay           String?   // MORNING | MIDDAY | EVENING | NIGHT (free text)
  crowdLevel          String?  

  carryMode     String?  
  phoneAttitude String?

  walks        TrajectoryWalk[]

  @@index([buildingId, floorLevel])
}

/// One continuous walk from a start waypoint (startX, startY) to an end
/// waypoint (endX, endY). `totalSteps` is the on-device step count between
/// the two taps; the server uses it to linearly interpolate a per-step (x, y)
/// label on the line segment.
model TrajectoryWalk {
  id          String              @id @default(cuid())
  session     TrajectorySession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String
  buildingId  String
  floorLevel  Int
  startX      Float
  startY      Float
  endX        Float
  endY        Float
  startedAt   DateTime
  endedAt     DateTime
  totalSteps  Int
  deviceModel String?
  createdAt   DateTime            @default(now())

  // Idempotency (B6): device-generated UUID per walk. uploadWalks() skips a
  // walk whose (sessionId, clientId) already exists so retries after a flaky
  // upload don't duplicate. Nullable for legacy rows.
  clientId    String?

  // Replay clock anchor (B1): wall-clock ms (Date.now()) captured at walk
  // start. Per-sample absolute time = clockEpochMs + tMs. The relative tMs on
  // each child row comes from a monotonic clock so it is immune to wall-clock
  // jumps mid-walk; clockEpochMs only maps the walk onto the calendar.
  clockEpochMs Float?

  // Sensor metadata (B5): the IMU sampling rate actually used and whether the
  // magnetometer was calibrated (Expo's magnetometer is uncalibrated → usually
  // null/false). Walk-level so mixed-device sessions stay analyzable.
  imuRateHz     Int?
  magCalibrated Boolean?

  steps       TrajectoryStepEvent[]
  imuSamples  TrajectoryImuSample[]
  bleReadings TrajectoryBleReading[]
  wifiReadings TrajectoryWifiReading[]
  checkpoints TrajectoryCheckpoint[]
  pauseEvents TrajectoryPauseEvent[]

  @@unique([sessionId, clientId])
  @@index([sessionId])
  @@index([buildingId, floorLevel])
}

model TrajectoryPauseEvent {
  id        String         @id @default(cuid())
  walk      TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId    String

  seq       Int    // 0-based pause order within the walk
  pauseTMs  Float  // monotonic ms from walk start when user pressed Pause
  resumeTMs Float? // monotonic ms when user pressed Resume (null = ended while paused)

  @@index([walkId, seq])
}

/// Intermediate ground-truth waypoint marked mid-walk (B2). The collector taps
/// "Mark checkpoint" when physically at a known (x, y); the server uses these
/// plus the start/end anchors to build a piecewise-linear time→position label,
/// so curved/non-uniform walks are labelled correctly (vs. the old straight-line
/// stepIndex/totalSteps assumption). `seq` orders them within the walk; `tMs` is
/// the same monotonic-relative clock as the IMU/BLE rows.
model TrajectoryCheckpoint {
  id         String         @id @default(cuid())
  walk       TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId     String

  seq        Int
  x          Float
  y          Float
  tMs        Float
  capturedAt DateTime

  @@index([walkId, seq])
}

/// One footstep detected on-device (peak-valley detector). `interpolatedX/Y`
/// is the server-computed label = start + (stepIndex / totalSteps) * (end - start).
model TrajectoryStepEvent {
  id             String          @id @default(cuid())
  walk           TrajectoryWalk  @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId         String

  stepIndex      Int             // 0-based within walk
  capturedAt     DateTime
  tMs            Float?          // monotonic ms since walk start (B1) — replay clock
  headingRad     Float           // device heading at the moment the step fired (relative yaw)
  compassDeg     Float?          // absolute OS-fused compass bearing (deg, 0=N, 90=E); legacy rows null
  interpolatedX  Float           // server-computed waypoint-anchored label
  interpolatedY  Float

  @@index([walkId, stepIndex])
}

/// Raw IMU stream at ~20 Hz. Column shape mirrors RawRssiReading's IMU columns
/// for AI-team familiarity. All sensor fields nullable — not every device emits
/// every channel.
model TrajectoryImuSample {
  id         String         @id @default(cuid())
  walk       TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId     String

  capturedAt DateTime
  tMs        Float?  // monotonic ms since walk start (B1) — replay clock

  // Gyroscope (rad/s)
  gyroX Float?
  gyroY Float?
  gyroZ Float?

  // Raw accelerometer including gravity (g)
  accelX Float?
  accelY Float?
  accelZ Float?

  // Gravity-removed acceleration (m/s²)
  userAccelX Float?
  userAccelY Float?
  userAccelZ Float?

  // Magnetometer (µT)
  magX Float?
  magY Float?
  magZ Float?

  // Attitude from OS-fused DeviceMotion (rad)
  pitch Float?
  roll  Float?
  yaw   Float?

  // Environmental
  pressure         Float?
  relativeAltitude Float?

  // On-device gait-detector state at this sample (lib/step-detector.ts). Lets the
  // AI team replay/debug walking classification offline and use it as features.
  // All nullable — legacy rows (recorded before this) have them null.
  vertAccel       Float?   // userAccel · ĝ (m/s²) — signed gravity-axis component (v5 gate input)
  gaitVerticality Float?   // Σvert²/Σ|userAccel|² over 500 ms (0–1; <0.25 ⇒ lateral shake)
  gaitEnergy      Float?   // recent-energy (variance of smoothed |userAccel|) — fast-stop signal
  gaitIsWalking   Boolean? // detector isWalking output at this sample
  gaitAmplitude   Float?   // adaptive peak-valley amplitude of |userAccel| used for step detection

  // Absolute OS-fused compass (use-heading). The absolute bearing the
  // relative/drifting DeviceMotion yaw lacks. Nullable — legacy rows null.
  compassDeg         Float? // smoothed compass bearing (deg, 0=N, 90=E)
  compassAccuracyDeg Float? // approx accuracy half-width (deg); larger = worse

  @@index([walkId, capturedAt])
}

/// One BLE advertisement captured during the walk.
model TrajectoryBleReading {
  id         String         @id @default(cuid())
  walk       TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId     String

  capturedAt DateTime
  tMs        Float?  // monotonic ms since walk start (B1) — replay clock
  beaconUid  String
  rssi       Int

  @@index([walkId, capturedAt])
  @@index([walkId, beaconUid])
}

/// One WiFi scan entry captured during the walk.
model TrajectoryWifiReading {
  id           String         @id @default(cuid())
  walk         TrajectoryWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  walkId       String

  capturedAt   DateTime
  tMs          Float?  // monotonic ms since walk start (B1) — replay clock
  bssid        String
  ssid         String?
  rssi         Int
  frequencyMhz Int?

  @@index([walkId, capturedAt])
  @@index([walkId, bssid])
}


model ChatSession {
  id         String                 @id @default(cuid())
  userId     String?
  user       User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  buildingId String
  building   Building               @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  title      String
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  messages   ChatPersistedMessage[]

  @@index([userId, buildingId])
}

model ChatPersistedMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    String      // "USER" | "ASSISTANT"
  text      String
  action    Json?       // type, poiId, floorLevel etc.
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model EmergencyAlert {
  id               String    @id @default(cuid())
  buildingId       String    @unique
  building         Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  isActive         Boolean   @default(false)
  message          String?
  gatheringPointId String?   // POI ID acting as gathering point
  blockedPoiIds    String[]  // List of blocked POI IDs (stairs/elevators)
  blockedZones     Json[]    // List of inaccessible area zones {x,y,w,h,floorLevel}
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

